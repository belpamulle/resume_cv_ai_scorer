# ---------------------------------------------------------------------------
# CV Assessor configuration. Copy this file to ".env" and fill in your values.
# Only the block for the PROVIDER you choose needs valid credentials.
# ---------------------------------------------------------------------------

# Which Claude backend to use: "bedrock" or "anthropic"
PROVIDER=bedrock

# --- IMAP (mailbox holding the job applications) ----------------------------
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=jobs@example.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX
# Optional: only fetch mail on/after this date (IMAP format: DD-Mon-YYYY). Leave blank for ALL.
IMAP_SINCE_DATE=
# Optional: cap how many emails to process this run. Leave blank for no cap.
MAX_EMAILS=

# --- Amazon Bedrock (used when PROVIDER=bedrock) ----------------------------
# Custom endpoint URL of your Bedrock-hosted gateway. Leave blank to use the AWS default.
BEDROCK_ENDPOINT_URL=
# Bedrock API key (bearer token). Enables API-key auth without AWS access keys.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Anthropic API (used when PROVIDER=anthropic) ---------------------------
ANTHROPIC_API_KEY=
# Optional: override base URL for proxies/gateways. Leave blank for the default.
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL_ID=claude-3-5-sonnet-20241022

# --- Application ------------------------------------------------------------
CRITERIA_FILE=criteria.txt
OUTPUT_CSV=candidates.csv
# Gentle pacing between API calls, in seconds (helps avoid throttling).
REQUEST_DELAY_SECONDS=1